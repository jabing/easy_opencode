// @ts-nocheck
function mergeProjectMemory(base = {}, patch = {}) {
  return {
    ...base,
    ...patch,
    naming: {
      ...(base.naming || {}),
      ...(patch.naming || {}),
    },
    preferred_feature_shape: Array.isArray(patch.preferred_feature_shape)
      ? patch.preferred_feature_shape.slice()
      : (Array.isArray(base.preferred_feature_shape) ? base.preferred_feature_shape.slice() : []),
    module_preference_stats: patch.module_preference_stats || base.module_preference_stats || {},
    generation_history: Array.isArray(patch.generation_history)
      ? patch.generation_history.slice()
      : (Array.isArray(base.generation_history) ? base.generation_history.slice() : []),
    semantic_feature_history: Array.isArray(patch.semantic_feature_history)
      ? patch.semantic_feature_history.slice()
      : (Array.isArray(base.semantic_feature_history) ? base.semantic_feature_history.slice() : []),
    feature_relations: patch.feature_relations || base.feature_relations || {},
    shared_error_module: patch.shared_error_module || base.shared_error_module || null,
    global_error_middleware: patch.global_error_middleware || base.global_error_middleware || null,
    app_entrypoint: patch.app_entrypoint || base.app_entrypoint || null,
    preferred_test_command: patch.preferred_test_command || base.preferred_test_command || null,
    preferred_test_commands: patch.preferred_test_commands || base.preferred_test_commands || null,
    preferred_test_runner_profile: patch.preferred_test_runner_profile || base.preferred_test_runner_profile || null,
    style_profile: {
      ...(base.style_profile || {}),
      ...(patch.style_profile || {}),
    },
  };
}

function normalizeFeatureShape(shape = []) {
  const canonical = ['route', 'controller', 'service', 'repository', 'schema', 'test', 'docs'];
  const requested = new Set((Array.isArray(shape) ? shape : []).map((item) => String(item || '').trim()).filter(Boolean));
  const picked = [];
  for (const key of canonical) {
    if (requested.has(key)) picked.push(key);
  }
  for (const key of canonical) {
    if (!requested.has(key)) picked.push(key);
  }
  return picked;
}


function trimHistory(items = [], limit = 12) {
  const list = Array.isArray(items) ? items.filter(Boolean) : [];
  return list.slice(-limit);
}

function updateModulePreferenceStats(base = {}, enabledModules = [], status = 'success') {
  const canonical = ['route', 'controller', 'service', 'repository', 'schema', 'test', 'docs'];
  const enabled = new Set((Array.isArray(enabledModules) ? enabledModules : []).map((item) => String(item || '').trim()).filter(Boolean));
  const next = { ...(base || {}) };
  for (const key of canonical) {
    const current = { ...(next[key] || {}) };
    current.enabled = Number(current.enabled || 0);
    current.disabled = Number(current.disabled || 0);
    current.success = Number(current.success || 0);
    current.failure = Number(current.failure || 0);
    if (enabled.has(key)) current.enabled += 1;
    else current.disabled += 1;
    if (status === 'success' && enabled.has(key)) current.success += 1;
    if (status === 'failure' && enabled.has(key)) current.failure += 1;
    next[key] = current;
  }
  return next;
}

function deriveAdaptiveFeatureShape(memory = {}) {
  const canonical = ['route', 'controller', 'service', 'repository', 'schema', 'test', 'docs'];
  const stats = memory.module_preference_stats || {};
  const ordered = [];
  for (const key of ['route', 'controller', 'service', 'schema']) ordered.push(key);
  const repositoryStats = stats.repository || {};
  if (Number(repositoryStats.enabled || 0) >= Number(repositoryStats.disabled || 0)) ordered.push('repository');
  const testStats = stats.test || {};
  const suppressTests = Number(testStats.failure || 0) >= 2 && Number(testStats.success || 0) === 0 && Number(testStats.disabled || 0) > 0;
  if (!suppressTests) ordered.push('test');
  const docsStats = stats.docs || {};
  if (Number(docsStats.enabled || 0) + Number(docsStats.success || 0) >= Number(docsStats.disabled || 0)) ordered.push('docs');
  for (const key of ['repository', 'test', 'docs']) {
    if (!ordered.includes(key)) ordered.push(key);
  }
  for (const key of canonical) {
    if (!ordered.includes(key)) ordered.push(key);
  }
  return ordered;
}


function updateFeatureRelations(base = {}, semantic = {}) {
  const next = { ...(base || {}) };
  const domainKey = String(semantic.domain_key || '').trim();
  if (!domainKey) return next;
  const current = { ...(next[domainKey] || { related_features: [], seen: 0, families: {} }) };
  current.related_features = Array.isArray(current.related_features) ? current.related_features.slice() : [];
  current.seen = Number(current.seen || 0) + 1;
  current.families = { ...(current.families || {}) };
  const family = String(semantic.family || 'general');
  current.families[family] = Number(current.families[family] || 0) + 1;
  for (const item of Array.isArray(semantic.relation_candidates) ? semantic.relation_candidates : []) {
    const value = String(item || '').trim();
    if (value && !current.related_features.includes(value)) current.related_features.push(value);
  }
  next[domainKey] = current;
  return next;
}

function appendSemanticHistory(memory = {}, entry = {}) {
  const history = trimHistory(memory.semantic_feature_history, 12);
  history.push({
    feature_name: entry.feature_name || null,
    family: entry.family || 'general',
    domain_key: entry.domain_key || null,
    route_namespace: entry.route_namespace || null,
    relation_candidates: Array.isArray(entry.relation_candidates) ? entry.relation_candidates.slice() : [],
    timestamp: entry.timestamp || new Date().toISOString(),
  });
  return trimHistory(history, 12);
}

function appendGenerationHistory(memory = {}, entry = {}) {
  const history = trimHistory(memory.generation_history, 12);
  history.push({
    feature_name: entry.feature_name || null,
    status: entry.status || 'success',
    enabled_modules: Array.isArray(entry.enabled_modules) ? entry.enabled_modules.slice() : [],
    implementation_style: entry.implementation_style || null,
    shape_strategy: entry.shape_strategy || null,
    plan_path: entry.plan_path || null,
    integration_note_path: entry.integration_note_path || null,
    integration_json_path: entry.integration_json_path || null,
    timestamp: entry.timestamp || new Date().toISOString(),
  });
  return trimHistory(history, 12);
}

function updateMemoryFromFeatureResult(memory = {}, details = {}) {
  const rawEnabledModules = Array.isArray(details.enabled_modules)
    ? details.enabled_modules.map((item) => String(item || '').trim()).filter(Boolean)
    : [];
  const status = details.status === 'failure' ? 'failure' : 'success';
  const preferredShape = rawEnabledModules.length
    ? normalizeFeatureShape(rawEnabledModules)
    : deriveAdaptiveFeatureShape(memory);
  const semantic = details.semantic || {};
  const next = mergeProjectMemory(memory, {
    preferred_feature_shape: preferredShape,
    module_preference_stats: updateModulePreferenceStats(memory.module_preference_stats || {}, rawEnabledModules, status),
    generation_history: appendGenerationHistory(memory, {
      feature_name: details.feature_name,
      status,
      enabled_modules: rawEnabledModules,
      implementation_style: details.implementation_style || memory.coding_style || 'functional',
      shape_strategy: details.shape_strategy || null,
      plan_path: details.plan_path || null,
      integration_note_path: details.integration_note_path || null,
      integration_json_path: details.integration_json_path || null,
    }),
    semantic_feature_history: appendSemanticHistory(memory, {
      feature_name: details.feature_name,
      family: semantic.family,
      domain_key: semantic.domain_key,
      route_namespace: semantic.route_namespace,
      relation_candidates: semantic.relation_candidates,
    }),
    feature_relations: updateFeatureRelations(memory.feature_relations || {}, semantic),
  });
  if (details.preferred_test_command) next.preferred_test_command = details.preferred_test_command;
  if (details.preferred_test_commands) next.preferred_test_commands = details.preferred_test_commands;
  if (details.preferred_test_runner_profile) next.preferred_test_runner_profile = details.preferred_test_runner_profile;
  if (details.failure_patterns) next.failure_patterns = details.failure_patterns;
  next.last_feature_generation = {
    feature_name: details.feature_name || null,
    status,
    implementation_style: details.implementation_style || memory.coding_style || 'functional',
    shape_strategy: details.shape_strategy || null,
    enabled_modules: rawEnabledModules,
    adaptive_preferred_shape: preferredShape,
    plan_path: details.plan_path || null,
    integration_note_path: details.integration_note_path || null,
    integration_json_path: details.integration_json_path || null,
    semantic_family: semantic.family || null,
    semantic_route_namespace: semantic.route_namespace || null,
    updated_at: new Date().toISOString(),
  };
  return next;
}


module.exports = {
  normalizeFeatureShape,
  trimHistory,
  updateModulePreferenceStats,
  deriveAdaptiveFeatureShape,
  updateFeatureRelations,
  appendSemanticHistory,
  appendGenerationHistory,
  updateMemoryFromFeatureResult,
};
