{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "noImplicitAny": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "lib": [
      "ES2020"
    ],
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.js",
    "src/**/*.d.ts"
  ]
}