{
  "name": "easy-opencode",
  "version": "1.9.10",
  "description": "Production-ready AI coding plugin for OpenCode with 15 specialized agents, 51 skills, 62 commands, and automated hook workflows.",
  "bin": {
    "eoc-install": "bin/eoc-install.js"
  },
  "scripts": {
    "install": "node scripts/npm-install.js",
    "postinstall": "node scripts/npm-postinstall.js",
    "quality-gate": "node scripts/quality-gate.js",
    "quality-gate:full": "node scripts/quality-gate.js --full --strict",
    "eoc:ultrawork": "node scripts/eoc-ultrawork.js",
    "hashline:annotate": "node scripts/hashline-edit.js annotate",
    "hashline:apply": "node scripts/hashline-edit.js apply",
    "ast:rewrite": "node scripts/ast-rewrite.js rename-symbol",
    "security:audit": "npm audit --omit=dev --audit-level=high",
    "coverage": "node scripts/runtime-coverage.js && node scripts/coverage-check.js --summary coverage/coverage-summary.json --threshold 80",
    "review:gate": "node scripts/review-gate.js",
    "lint": "node scripts/metadata-check.js",
    "typecheck": "node scripts/typecheck.js",
    "test": "node scripts/test-core-pipeline.js && node scripts/regression-suite.js",
    "build": "node scripts/build-check.js"
  },
  "keywords": [
    "opencode",
    "ai",
    "agents",
    "coding",
    "tdd",
    "development",
    "productivity"
  ],
  "author": "Everything OpenCode Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jabing/easy_opencode.git"
  },
  "bugs": {
    "url": "https://github.com/jabing/easy_opencode/issues"
  },
  "homepage": "https://github.com/jabing/easy_opencode#readme",
  "engines": {
    "node": ">=14.0.0"
  },
  "files": [
    "skills/",
    "commands/",
    "prompts/",
    ".opencode/",
    "AGENTS.md",
    "scripts/",
    "bin/",
    "docs/",
    "diagnose-eoc.ps1",
    "logo.svg",
    "favicon.ico",
    "logo-monochrome.svg"
  ],
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "eslint": "^10.0.3",
    "jest": "^30.3.0",
    "typescript": "^5.9.3"
  }
}
